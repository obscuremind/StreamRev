[Unit]
Description=StreamRev Supervisor
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/streamrev
Environment=PYTHONPATH=/opt/streamrev
ExecStart=/usr/bin/python3 -m src.service start
ExecStop=/usr/bin/python3 -m src.service stop
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
