#!/bin/bash

################################################################################
# StreamRev Installation Script
# 
# This script installs StreamRev IPTV backend platform on Ubuntu 22.04/24.04 LTS
################################################################################

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Configuration
INSTALL_DIR="/opt/streamrev"
DB_NAME="streamrev"
DB_USER="streamrev"
DB_PASSWORD=""

################################################################################
# Helper Functions
################################################################################

print_info() {
    echo -e "${GREEN}[INFO]${NC} $1"
}

print_warn() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

print_error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

check_root() {
    if [ "$EUID" -ne 0 ]; then
        print_error "This script must be run as root"
        exit 1
    fi
}

check_os() {
    if [ ! -f /etc/os-release ]; then
        print_error "Cannot determine OS version"
        exit 1
    fi
    
    . /etc/os-release
    
    if [ "$ID" != "ubuntu" ]; then
        print_error "This script is designed for Ubuntu"
        exit 1
    fi
    
    if [ "$VERSION_ID" != "22.04" ] && [ "$VERSION_ID" != "24.04" ]; then
        print_warn "This script is tested on Ubuntu 22.04 and 24.04 LTS"
        read -p "Continue anyway? (y/n) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 1
        fi
    fi
    
    print_info "OS check passed: Ubuntu $VERSION_ID"
}

generate_password() {
    openssl rand -base64 32 | tr -d "=+/" | cut -c1-25
}

################################################################################
# Installation Steps
################################################################################

update_system() {
    print_info "Updating system packages..."
    apt-get update -qq
    apt-get upgrade -y -qq
}

install_dependencies() {
    print_info "Installing dependencies..."
    
    apt-get install -y -qq \
        python3 \
        python3-pip \
        python3-venv \
        nginx \
        mariadb-server \
        redis-server \
        ffmpeg \
        git \
        curl \
        wget \
        unzip \
        software-properties-common
    
    print_info "Dependencies installed successfully"
}

setup_database() {
    print_info "Setting up MariaDB database..."
    
    # Start MariaDB
    systemctl start mariadb
    systemctl enable mariadb
    
    # Generate database password
    DB_PASSWORD=$(generate_password)
    
    # Create database and user
    mysql -e "CREATE DATABASE IF NOT EXISTS ${DB_NAME};"
    mysql -e "CREATE USER IF NOT EXISTS '${DB_USER}'@'localhost' IDENTIFIED BY '${DB_PASSWORD}';"
    mysql -e "GRANT ALL PRIVILEGES ON ${DB_NAME}.* TO '${DB_USER}'@'localhost';"
    mysql -e "FLUSH PRIVILEGES;"
    
    print_info "Database setup completed"
    print_info "Database: ${DB_NAME}"
    print_info "Username: ${DB_USER}"
    print_info "Password: ${DB_PASSWORD}"
    
    # Save credentials
    echo "${DB_PASSWORD}" > /root/.streamrev_db_password
    chmod 600 /root/.streamrev_db_password
}

setup_redis() {
    print_info "Setting up Redis..."
    
    systemctl start redis-server
    systemctl enable redis-server
    
    # Configure Redis
    sed -i 's/^bind 127.0.0.1/bind 127.0.0.1/' /etc/redis/redis.conf
    sed -i 's/^# maxmemory <bytes>/maxmemory 256mb/' /etc/redis/redis.conf
    sed -i 's/^# maxmemory-policy noeviction/maxmemory-policy allkeys-lru/' /etc/redis/redis.conf
    
    systemctl restart redis-server
    
    print_info "Redis setup completed"
}

install_streamrev() {
    print_info "Installing StreamRev..."
    
    # Create installation directory
    mkdir -p ${INSTALL_DIR}
    
    # Copy or clone StreamRev files
    if [ -d "$(pwd)/src" ]; then
        print_info "Copying StreamRev files from current directory..."
        cp -r $(pwd)/* ${INSTALL_DIR}/
    else
        print_info "Downloading StreamRev..."
        git clone https://github.com/obscuremind/StreamRev.git ${INSTALL_DIR}
    fi
    
    # Create virtual environment
    cd ${INSTALL_DIR}
    python3 -m venv venv
    source venv/bin/activate
    
    # Install Python dependencies
    pip install --upgrade pip -q
    pip install -r requirements.txt -q
    
    # Create necessary directories
    mkdir -p /var/streams/live
    mkdir -p /var/streams/vod
    mkdir -p /var/log/streamrev
    
    # Set permissions
    chown -R www-data:www-data /var/streams
    chown -R www-data:www-data /var/log/streamrev
    
    print_info "StreamRev installed successfully"
}

setup_database_schema() {
    print_info "Setting up database schema..."
    
    if [ -f "${INSTALL_DIR}/src/database/schema.sql" ]; then
        mysql -u${DB_USER} -p${DB_PASSWORD} ${DB_NAME} < ${INSTALL_DIR}/src/database/schema.sql
        print_info "Database schema created successfully"
    else
        print_warn "Database schema file not found"
    fi
}

setup_config() {
    print_info "Setting up configuration..."
    
    # Create config from example
    if [ -f "${INSTALL_DIR}/configs/config.json.example" ]; then
        cp ${INSTALL_DIR}/configs/config.json.example ${INSTALL_DIR}/config.json
        
        # Update config with actual values
        SECRET_KEY=$(generate_password)
        
        sed -i "s/your-secure-password/${DB_PASSWORD}/" ${INSTALL_DIR}/config.json
        sed -i "s/generate-a-secure-random-key-here/${SECRET_KEY}/" ${INSTALL_DIR}/config.json
        
        print_info "Configuration file created: ${INSTALL_DIR}/config.json"
    fi
}

setup_nginx() {
    print_info "Setting up Nginx..."
    
    # Copy Nginx config
    if [ -f "${INSTALL_DIR}/configs/nginx.conf.example" ]; then
        cp ${INSTALL_DIR}/configs/nginx.conf.example /etc/nginx/sites-available/streamrev
        
        # Enable site
        ln -sf /etc/nginx/sites-available/streamrev /etc/nginx/sites-enabled/streamrev
        
        # Remove default site
        rm -f /etc/nginx/sites-enabled/default
        
        # Test configuration
        nginx -t
        
        # Restart Nginx
        systemctl restart nginx
        systemctl enable nginx
        
        print_info "Nginx configured successfully"
    fi
}

setup_systemd() {
    print_info "Setting up systemd service..."
    
    # Create systemd service file
    cat > /etc/systemd/system/streamrev.service <<EOF
[Unit]
Description=StreamRev IPTV Backend
After=network.target mariadb.service redis-server.service

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=${INSTALL_DIR}
Environment="PATH=${INSTALL_DIR}/venv/bin"
ExecStart=${INSTALL_DIR}/venv/bin/python -m src.api.server
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
EOF
    
    # Reload systemd
    systemctl daemon-reload
    systemctl enable streamrev
    systemctl start streamrev
    
    print_info "StreamRev service created and started"
}

show_summary() {
    print_info "=============================================="
    print_info "StreamRev Installation Complete!"
    print_info "=============================================="
    print_info ""
    print_info "Database Credentials:"
    print_info "  Database: ${DB_NAME}"
    print_info "  Username: ${DB_USER}"
    print_info "  Password: ${DB_PASSWORD}"
    print_info ""
    print_info "Default Admin Credentials:"
    print_info "  Username: admin"
    print_info "  Password: admin123"
    print_info "  ⚠️  CHANGE THIS PASSWORD IMMEDIATELY!"
    print_info ""
    print_info "Installation Directory: ${INSTALL_DIR}"
    print_info "Configuration File: ${INSTALL_DIR}/config.json"
    print_info ""
    print_info "Services Status:"
    systemctl is-active --quiet mariadb && print_info "  MariaDB: Running" || print_warn "  MariaDB: Not Running"
    systemctl is-active --quiet redis-server && print_info "  Redis: Running" || print_warn "  Redis: Not Running"
    systemctl is-active --quiet nginx && print_info "  Nginx: Running" || print_warn "  Nginx: Not Running"
    systemctl is-active --quiet streamrev && print_info "  StreamRev: Running" || print_warn "  StreamRev: Not Running"
    print_info ""
    print_info "Access StreamRev:"
    print_info "  API: http://$(hostname -I | awk '{print $1}'):5000"
    print_info "  Web: http://$(hostname -I | awk '{print $1}')"
    print_info ""
    print_info "Next Steps:"
    print_info "  1. Change the default admin password"
    print_info "  2. Configure your domain in /etc/nginx/sites-available/streamrev"
    print_info "  3. Set up SSL certificate (recommended)"
    print_info "  4. Review configuration in ${INSTALL_DIR}/config.json"
    print_info ""
    print_info "Documentation: https://github.com/obscuremind/StreamRev"
    print_info "=============================================="
}

################################################################################
# Main Installation
################################################################################

main() {
    print_info "Starting StreamRev installation..."
    print_info ""
    
    check_root
    check_os
    
    update_system
    install_dependencies
    setup_database
    setup_redis
    install_streamrev
    setup_database_schema
    setup_config
    setup_nginx
    setup_systemd
    
    show_summary
}

# Run main installation
main
