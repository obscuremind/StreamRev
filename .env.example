# IPTV Panel Configuration
# Copy this file to .env and adjust values

# Security
IPTV_SECRET_KEY=change-this-to-a-random-secret-key
IPTV_DEBUG=false

# Database (MySQL/MariaDB)
IPTV_DB_HOST=localhost
IPTV_DB_PORT=3306
IPTV_DB_USER=iptv
IPTV_DB_PASSWORD=iptv
IPTV_DB_NAME=iptv_panel

# Redis
IPTV_REDIS_HOST=localhost
IPTV_REDIS_PORT=6379
IPTV_REDIS_DB=0
IPTV_REDIS_PASSWORD=

# Server
IPTV_SERVER_HOST=0.0.0.0
IPTV_SERVER_PORT=8000
IPTV_SERVER_PROTOCOL=http

# JWT
IPTV_JWT_ALGORITHM=HS256
IPTV_JWT_EXPIRATION_HOURS=24

# Streaming
IPTV_FFMPEG_PATH=/usr/bin/ffmpeg
IPTV_FFPROBE_PATH=/usr/bin/ffprobe
IPTV_STREAM_TIMEOUT=30
IPTV_MAX_CONNECTIONS_PER_USER=1

# GeoIP
IPTV_GEOIP_DB_PATH=
IPTV_STREAMING_ALLOW_COUNTRIES=

# Security
IPTV_STREAMING_LOG_RESTREAM_DETECT=true
IPTV_STREAMING_BLOCK_RESTREAM_DETECT=false
IPTV_STREAMING_HMAC_MAX_SKEW_SECONDS=300

# Nginx
IPTV_NGINX_BIN=/usr/sbin/nginx
IPTV_NGINX_CONF_DIR=
